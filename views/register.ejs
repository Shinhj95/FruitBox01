<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Register</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <%- include('menu/nav') %>

    <% if (error) { %>
    <script>
        window.onload = () => {
            showModal("<%= error %>");
        }
    </script>
    <% } %>

    <div class="auth-page">

        <div class="auth-card">

            <h1>회원가입</h1>

            <form method="POST" action="/auth/register">

                <input name="username" placeholder="아이디" autocomplete="username">
                <input type="password" name="password" placeholder="비밀번호" autocomplete="new-password">
                <input type="password" name="passwordConfirm" placeholder="비밀번호 확인" autocomplete="new-password" required>

                <button>회원가입</button>

            </form>

            <a class="auth-link" href="/auth/login">
                이미 계정이 있나요? 로그인
            </a>

        </div>

    </div>

</body>
</html>